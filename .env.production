# Production Environment Variables
# Copy this file and fill in your production values

# Database (for Docker deployment, use volume mount)
DATABASE_URL="file:/app/data/production.db"

# Anthropic API Key (REQUIRED)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Clerk Authentication (REQUIRED)
# IMPORTANT: Set this in Railway as a BUILD-TIME environment variable
# Vite requires this at build time, not runtime!
# Get your key from: https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key-here

# Server Configuration
NODE_ENV=production
PORT=3001

# Optional: If using PostgreSQL in production instead of SQLite
# DATABASE_URL="postgresql://user:password@host:5432/dbname"
