generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Client model for agency workflow - groups packs by customer
model Client {
  id           String   @id @default(uuid())
  name         String
  company      String?
  contactEmail String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  packs        Pack[]

  // AI-generated summary (cached)
  aiSummary        String?
  summaryUpdatedAt DateTime?
}

model Pack {
  id        String        @id @default(uuid())
  name      String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt @default(now())
  versions  PackVersion[]
  tasks     PackTask[]

  // Client relationship for agency workflow
  clientId  String?
  client    Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Service package type
  servicePackage String?   // gap_assessment, full_pack_prep, compliance_review, ongoing_support

  // Initial requirements/brief captured at project kickoff
  requirements   String?

  // AI-generated summary (cached)
  aiSummary      String?
  summaryUpdatedAt DateTime?
}

// Task/checklist items for tracking pack progress
model PackTask {
  id          String    @id @default(uuid())
  packId      String
  pack        Pack      @relation(fields: [packId], references: [id], onDelete: Cascade)
  title       String
  description String?
  completed   Boolean   @default(false)
  completedAt DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([packId])
}

model PackVersion {
  id            String           @id @default(uuid())
  packId        String
  pack          Pack             @relation(fields: [packId], references: [id], onDelete: Cascade)
  versionNumber Int
  createdAt     DateTime         @default(now())
  documents     Document[]
  fields        ExtractedField[]
  issues        IssueAction[]
  artifacts     OutputArtifact[]

  // Optional user inputs
  projectName  String?
  borough      String?
  buildingType String?
  height       String?
  storeys      String?
  targetDate   DateTime?

  // Matrix assessment result (JSON)
  matrixAssessment String?

  @@unique([packId, versionNumber])
}

model Document {
  id              String           @id @default(uuid())
  packVersionId   String?
  packVersion     PackVersion?     @relation(fields: [packVersionId], references: [id], onDelete: Cascade)
  libraryType     String           // pack, baseline, butler
  filename        String
  filepath        String
  docType         String?
  source          String?
  createdAt       DateTime         @default(now())
  chunks          Chunk[]
  extractedFields ExtractedField[]
}

model Chunk {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex Int
  text       String
  pageRef    Int
}

model ExtractedField {
  id                 String       @id @default(uuid())
  packVersionId      String
  packVersion        PackVersion  @relation(fields: [packVersionId], references: [id], onDelete: Cascade)
  fieldName          String
  fieldValue         String?
  confidence         String       // high, medium, low
  evidenceDocumentId String?
  evidenceDocument   Document?    @relation(fields: [evidenceDocumentId], references: [id])
  evidencePageRef    Int?
  evidenceQuote      String?
}

model IssueAction {
  id                   String      @id @default(uuid())
  packVersionId        String
  packVersion          PackVersion @relation(fields: [packVersionId], references: [id], onDelete: Cascade)
  severity             String      // high, medium, low
  category             String
  title                String
  finding              String
  whyItMatters         String
  action               String
  ownerRole            String
  effort               String      // S, M, L
  endUserConsideration String
  expectedBenefit      String
  confidence           String      // high, medium, low
  citations            String      // JSON string
  evidence             String      // JSON string
  createdAt            DateTime    @default(now())
}

model OutputArtifact {
  id            String      @id @default(uuid())
  packVersionId String
  packVersion   PackVersion @relation(fields: [packVersionId], references: [id], onDelete: Cascade)
  artifactType  String      // md, pdf, json
  path          String
  createdAt     DateTime    @default(now())
}

// Auth & Subscription models
model StripeCustomer {
  id               String   @id @default(uuid())
  userId           String   @unique // Clerk user ID
  stripeCustomerId String   @unique
  createdAt        DateTime @default(now())
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String
  stripeSubscriptionId String   @unique
  plan                 String   // professional, enterprise
  status               String   // active, cancelled, inactive
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// Track submissions per user
model SubmissionUsage {
  id            String   @id @default(uuid())
  userId        String
  packVersionId String   @unique
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
}

// Track purchased submission credits (pay-as-you-go)
model SubmissionCredit {
  id                String   @id @default(uuid())
  userId            String
  stripePaymentId   String?  @unique
  creditsRemaining  Int      @default(1)
  createdAt         DateTime @default(now())

  @@index([userId])
}
