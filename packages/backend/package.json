{
  "name": "@bsr/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "bash start.sh",
    "db:setup": "prisma generate && prisma migrate dev --name init && npm run ingest:baseline",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "ingest:baseline": "tsx src/scripts/ingestBaseline.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@clerk/express": "^1.7.73",
    "@prisma/client": "5.22.0",
    "cors": "^2.8.5",
    "docx": "^9.5.3",
    "express": "^4.21.1",
    "marked": "^4.3.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^23.6.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^10.0.0",
    "prisma": "5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
