  "description": "BSR Gateway 2 Quality Assessment Criteria Matrix",
  "criteria_types": {
    "LLM_ONLY": "Can be assessed using pack documents alone without reference corpus",
    "CORPUS_BACKED": "Must cite specific reference document(s) from corpus to assess",
    "HYBRID": "Uses both pack evidence and corpus reference standards"
  },
  "categories": [
    {
      "id": "COMPLETENESS",
      "name": "Pack Completeness vs Gateway 2 Expectations",
      "description": "Checks that required documents are present per BSR Gateway 2 guidance"
    },
    {
      "id": "GOLDEN_THREAD",
      "name": "Golden Thread & Information Management",
      "description": "Checks compliance with golden thread information requirements"
    },
    {
      "id": "HRB_DUTIES",
      "name": "HRB Process Duties & Roles",
      "description": "Checks evidence of dutyholder competence and role clarity"
    },
    {
      "id": "FIRE_SAFETY",
      "name": "Fire Safety Narrative Quality",
      "description": "Checks fire strategy against Approved Document B expectations"
    },
    {
      "id": "STRUCTURAL",
      "name": "Structural Safety Information",
      "description": "Checks structural documentation completeness"
    },
    {
      "id": "VENTILATION",
      "name": "Ventilation Systems",
      "description": "Checks ventilation strategy against Approved Document F"
    },
    {
      "id": "LONDON_PLANNING",
