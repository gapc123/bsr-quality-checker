      "pack_evidence_required": ["Fire Strategy Report", "Fire Safety Strategy"],
      "reference_docs": ["clc_gateway2_guidance_suite", "building_control_approval_hrb"],
      "applicability": {
        "hrb_only": true,
        "london_only": false,
        "building_types": ["all"],
        "height_threshold": null
      },
      "output": {
        "status_options": ["pass", "flag", "not_found"],
        "severity_if_flagged": "high",
        "confidence_guidance": "High if document clearly titled; Medium if inferred from content"
