    },
    {
      "id": "TRACEABILITY",
      "name": "Document Traceability & Cross-Referencing",
      "description": "Checks that documents reference each other consistently"
    },
    {
      "id": "CONSISTENCY",
      "name": "Internal Consistency",
      "description": "Checks for contradictions within pack documents"
    }
  ],
